<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="4dp"
                android:paddingRight="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:text="@string/uitleg_icons_title"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:paddingBottom="8dp" />

                <Button
                    android:id="@+id/uitleg_stoor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/stoor"
                    android:textColor="#FFFF"
                    android:background="@drawable/buttonshape"
                    android:layout_marginBottom="8dp" />

                <CheckBox
                    android:id="@+id/uitleg_foto"
                    android:text="@string/uitleg_foto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_epos"
                    android:text="@string/uitleg_epos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_whatsap"
                    android:text="@string/uitleg_whatsapp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_verjaarsdag"
                    android:text="@string/uitleg_verjaarsdag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_ouderdom"
                    android:text="@string/filter_ouderdom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_Huweliksdag"
                    android:text="@string/uitleg_huweliksdatum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_wyk"
                    android:text="@string/list_wyk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_selfoon"
                    android:text="@string/list_selfoon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_telefoon"
                    android:text="@string/list_telefoon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- Widget Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:text="@string/uitleg_widget_title"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp" />

                <Button
                    android:id="@+id/save_widget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/stoor"
                    android:textColor="#FFFF"
                    android:background="@drawable/buttonshape"
                    android:layout_marginBottom="8dp" />

                <CheckBox
                    android:id="@+id/widget_Doop_select"
                    android:text="@string/uitleg_doopdatum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/widget_Belydenis_select"
                    android:text="@string/uitleg_belydenisdatum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/widget_Huwelik_select"
                    android:text="@string/uitleg_huweliksdatum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/widget_Sterf"
                    android:text="@string/uitleg_sterfdatum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingLeft="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:text="@string/uitleg_funksies_title"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:paddingBottom="8dp" />

                <Button
                    android:id="@+id/funksoie_Stoor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/stoor"
                    android:textColor="#FFFF"
                    android:background="@drawable/buttonshape"
                    android:layout_marginBottom="8dp" />

                <CheckBox
                    android:id="@+id/autoStartSwitch"
                    android:text="@string/uitleg_autostart_monitor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_Monitor_Oproepe"
                    android:text="@string/uitleg_monitor_oproepe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_Log_Oproepe"
                    android:text="@string/uitleg_log_tel_oproepe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_Log_VOIP"
                    android:text="@string/uitleg_log_voip_oproepe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/uitleg_calendar_picker"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/calendarSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:minHeight="48dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/uitleg_default_layout"
                    android:textSize="16sp"
                    android:paddingTop="8dp" />

                <Spinner
                    android:id="@+id/layoutOpsies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:entries="@array/layoutoptions"
                    android:minHeight="48dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/uitleg_whatsapp_label"
                    android:textSize="16sp"
                    android:paddingTop="8dp" />

                <CheckBox
                    android:id="@+id/uitleg_w1"
                    android:text="@string/uitleg_whatsapp_method_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_w2"
                    android:text="@string/uitleg_whatsapp_method_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/uitleg_w3"
                    android:text="@string/uitleg_whatsapp_method_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/uitleg_epos_label"
                    android:textSize="16sp"
                    android:paddingTop="8dp" />

                <CheckBox
                    android:id="@+id/uitleg_html"
                    android:text="@string/uitleg_html_epos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/saveColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/uitleg_stoor_kleur"
                    android:textColor="#FFFF"
                    android:background="@drawable/buttonshape"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/gem1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/uitleg_gemeente_1"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:backgroundTint="@null"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:outlineProvider="none" />

                <TextView
                    android:id="@+id/gem2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/uitleg_gemeente_2"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:backgroundTint="@null"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:outlineProvider="none" />

                <TextView
                    android:id="@+id/gem3"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/uitleg_gemeente_3"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:backgroundTint="@null"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:outlineProvider="none" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>